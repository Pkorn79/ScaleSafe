# ============================================
# ScaleSafe Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to the repo
# ============================================

# GHL Marketplace App (from GHL Developer Portal)
GHL_APP_CLIENT_ID=
GHL_APP_CLIENT_SECRET=
GHL_APP_SSO_KEY=
GHL_API_DOMAIN=https://services.leadconnectorhq.com

# Supabase (from Supabase project settings)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Claude API (for AI Defense Compiler)
ANTHROPIC_API_KEY=

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
