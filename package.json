{
  "name": "scalesafe",
  "version": "1.0.0",
  "description": "ScaleSafe — Chargeback defense SaaS for high-ticket coaching businesses. GHL Marketplace app.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build-ui && mkdir -p ./dist/ui && cp -r ./src/ui/dist ./dist/ui/dist",
    "build-ui": "cd src/ui && npm install && npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pkorn79/ScaleSafe.git"
  },
  "author": "ScaleSafe",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.5.1",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pdfkit": "^0.18.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.3",
    "qs": "^6.11.2",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.2",
    "@types/pdfkit": "^0.17.5",
    "@types/qs": "^6.9.9",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
